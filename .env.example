# Optional environment overrides for mario_task.
# These OVERRIDE values in config.json. Most users should configure via the
# first-run config wizard (auto-launched on first `bash run.sh`) and leave
# this file alone.

# Trigger backend: lsl | serial | parallel | null
# MARIO_TRIGGER_BACKEND=lsl
# MARIO_TRIGGER_PORT=/dev/ttyACM0      # Linux serial example
# MARIO_TRIGGER_PORT=COM3              # Windows serial example
# MARIO_TRIGGER_PORT=/dev/parport1     # Linux parallel example

# LSL stream metadata (only used when backend = lsl)
# LSL_STREAM_NAME=mario_task
# LSL_STREAM_TYPE=Markers
# LSL_STREAM_SOURCE_ID=mario_task_markers

# Run duration in seconds (default 600 = 10 min)
# MARIO_MAX_DURATION=600

# Display overrides (mostly for debugging on a single-monitor dev box)
# EXP_WIN_FULLSCR=0
# EXP_WIN_SCREEN=0
# EXP_WIN_W=1280
# EXP_WIN_H=720
